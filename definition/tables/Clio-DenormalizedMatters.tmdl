	column MatchID =

			IF(
			    ISBLANK('Clio-DenormalizedMatters'[ClientReference]) || 'Clio-DenormalizedMatters'[ClientReference] = "",
			    "NO_MATCH_" & FORMAT('Clio-DenormalizedMatters'[Id], "0"),
			    'Clio-DenormalizedMatters'[ClientReference]
			)
		lineageTag: 7bb65dd0-cfe2-4f1d-9544-ba369e4cd3e0
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition Clio-DenormalizedMatters = m
		mode: import
		source =
				let
				    Source = GoogleBigQuery.Database([Implementation="2.0"]),
				    #"caramel-compass-452313-u3_Database" = Source{[Name="caramel-compass-452313-u3",Kind="Database"]}[Data],
				    clio_manage_Schema = #"caramel-compass-452313-u3_Database"{[Name="clio_manage",Kind="Schema"]}[Data],
				    DenormalizedMatters_View = clio_manage_Schema{[Name="DenormalizedMatters",Kind="View"]}[Data]
				in
				    DenormalizedMatters_View

	changedProperty = Name

	annotation PBI_ResultType = Table
